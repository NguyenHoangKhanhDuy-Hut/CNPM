# Database - Microsoft SQL Server (pymssql driver, SQL Server Authentication)
# Default sa password: MediPredict2024
DATABASE_URL=mssql+pymssql://sa:123456@localhost:1433/medipredict

# Server
HOST=0.0.0.0
PORT=8000

# JWT
