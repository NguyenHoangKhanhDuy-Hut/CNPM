<script>
        // Simple micro-interaction for filter toggles
        document.querySelectorAll('input[type="checkbox"], input[type="radio"]').forEach(input => {
            input.addEventListener('change', function() {
                // Mimic a loading state in a low-fi way
                const contentGrid = document.querySelector('.grid');
                contentGrid.style.opacity = '0.5';
                setTimeout(() => {
                    contentGrid.style.opacity = '1';
                }, 300);
            });
        });

        // Hover effect for drug cards
        document.querySelectorAll('.group').forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.style.transform = 'translateY(-4px)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'translateY(0)';
            });
        });
    </script>
